  "topic": "Density",
  "question": "What is density?",
  "options": {
    "A": "Mass per unit volume",
    "B": "Volume per unit mass",
    "C": "Atoms per unit volume",
    "D": "Weight per unit area"
  },
  "answer": "A",
  "explanation": "Density (\u03c1) = mass/volume. Common units: g/mL or g/cm\u00b3. Water = 1 g/mL."
}