  "unit_name": "Stoichiometric Calculations",
  "topic": "Mole Concept",
  "question": "What is the molar mass of Ca(OH)\u2082?",
  "options": {
    "A": "40 g/mol",
    "B": "57 g/mol",
    "C": "74 g/mol",
    "D": "92 g/mol"
  },
  "answer": "C",
  "explanation": "Molar mass Ca(OH)\u2082 = 40 (Ca) + 2[16 (O) + 1 (H)] = 40 + 2(17) = 40 + 34 = 74 g/mol"
}